println("17. optional: skipped")

# --- 18. Type checking ---
typed_add(a: int, b: int): int
    return a + b
println("18. typed: {typed_add!(3, 4)}")

# --- 19. For loop + range ---
total = 0
for i in range(1, 101)
    total = total + i
println("19. range sum: {total}")

# --- 20. While with break/continue ---
count = 0
i = 0
while i < 100
    i++
    if i % 2 == 0
        continue
    if i > 50
        break
    count++
println("20. break/continue: {count}")

