# Deploy Readiness Check

print!!("=== Deploy Check ===")

status? = git("status", "--porcelain")
if status?
    if len(trim(status.out)) > 0
        print!!("WARN: Dirty working tree")
    else
        print!!("OK: Clean")

branch? = git("rev-parse", "--abbrev-ref", "HEAD")
if branch?
    print!!("Branch: {trim(branch.out)}")

log? = git("log", "--oneline", "-1")
if log?
    print!!("Commit: {trim(log.out)}")

print!!("OS: {os!!()}")
print!!("=== Done ===")

