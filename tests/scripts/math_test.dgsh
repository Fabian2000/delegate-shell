# Math test
println("abs_num(-5): " + str(abs_num(-5)))
println("abs_num(-3.14): " + str(abs_num(-3.14)))
println("ceil(2.3): " + str(ceil(2.3)))
println("floor(2.9): " + str(floor(2.9)))
println("round(2.567, 1): " + str(round(2.567, 1)))
println("round(2.5): " + str(round(2.5)))
println("sqrt(16): " + str(sqrt(16)))
println("pow(2, 10): " + str(pow(2, 10)))
println("log(1): " + str(log!!(1)))
println("log10(100): " + str(log10(100)))
println("sin(0): " + str(sin(0)))
println("cos(0): " + str(cos(0)))
println("tan(0): " + str(tan(0)))
println("pi: " + str(pi()))
println("infinity: " + str(infinity()))
r = random()
println("random: " + str(r))
ri = random_int(1, 100)
println("random_int: " + str(ri))
