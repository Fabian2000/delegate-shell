# Variables and arithmetic
x = 42
y = 8
print!!(x + y)
print!!(x * 2)
print!!(x - y)
print!!(x / y)
print!!(x % y)
print!!(2 ** 10)

# Strings and interpolation
name = "World"
print!!("Hello {name}")

# Boolean
flag = true
print!!(flag)
print!!(!flag)

# List
nums = [1, 2, 3, 4, 5]
print!!(nums)
print!!(len(nums))
print!!(nums[0])
print!!(nums[4])

# Object
person = { name = "Alice", age = 30 }
print!!(person.name)
print!!(person.age)
print!!(has(person, "name"))
print!!(has(person, "email"))

# Type checking
print!!(type(42))
print!!(type("hello"))
print!!(type(true))
print!!(type([1, 2]))
print!!(type({ a = 1 }))

# String operations
print!!(upper("hello"))
print!!(lower("HELLO"))
print!!(trim("  hello  "))
print!!(replace("hello world", "world", "shell"))
print!!(contains("hello", "ell"))

# Comparisons (type-strict)
print!!(1 == 1)
print!!(1 == 2)
print!!("a" == "a")
print!!(1 < 2)
print!!(2 > 1)

# Bitwise
print!!(0b1010 & 0b1100)
print!!(0b1010 | 0b1100)
print!!(0b1010 ^ 0b1100)
print!!(1 << 4)
print!!(16 >> 2)

# Ranges
r = 1..5
print!!(r)

# Compound assignment
c = 10
c += 5
print!!(c)
c *= 2
print!!(c)
