# Index assign
items = [10, 20, 30, 40]
items[1] = 99
items[3] = 77
println("List: " + str(items))

# Field assign
user = { name = "Alice", age = 25 }
user.age = 30
user.name = "Bob"
println("User: " + str(user))

# Use in wordcount-style loop
vals = [0, 0, 0]
vals[0] = vals[0] + 5
vals[1] = vals[1] + 10
vals[2] = vals[2] + 15
println("Vals: " + str(vals))
