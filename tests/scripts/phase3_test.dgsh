# === SEND OPERATOR ===

# Basic send with implicit $
double(x)
    return x * 2

result = 5 -> double!($)
print!!("send basic: {result}")

# Send with $field on object
data = { name = "Alice", age = 30 }
data -> print!!("Name: {$name}")

# Send chaining
triple(x)
    return x * 3

result = 2 -> double!($) -> triple!($)
print!!("send chain: {result}")

# === ERROR HANDLING ===

# Error-tolerant assignment
x? = int("not_a_number")
if x?
    print!!("unexpected success")
else
    print!!("caught error (expected)")

# Successful error-tolerant
y? = int("42")
if y?
    print!!("y = {y}")
else
    print!!("unexpected error")

# === LAMBDAS ===

# Lambda reference
ref = @double!
result = ref(21)
print!!("lambda call: {result}")

# Lambda with pre-bound args
greeter = @print!!("Hello from lambda")
greeter()

# === ONE-LINERS ===
z = 100
if z > 50; :print!!("one-liner works")

# === COMPREHENSIVE ===
numbers = [10, 20, 30, 40, 50]

# For + if
for n in numbers
    if n > 25
        print!!("big: {n}")

print!!("done")
