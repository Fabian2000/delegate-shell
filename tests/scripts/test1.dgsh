# Basic variables and arithmetic
x = 42
y = 8
println(x + y)
println(x * 2)
println(x - y)

# Strings
name = "World"
println("Hello {name}")

# Boolean
flag = true
println(flag)

# List
nums = [1, 2, 3, 4, 5]
println(nums)
println(len(nums))

# Object
person = { name = "Alice", age = 30 }
println(person.name)
println(person.age)

# Type checking
println(type(42))
println(type("hello"))
println(type(true))
println(type([1, 2]))
