# === EXTERNAL COMMANDS ===

# ls is an exe — returns CommandResult
r? = ls("-la", "/tmp")
if r?
    echo!!("ls status: {r.status}")
    echo!!("ls ran successfully")

# === IMPORT ===
import "tests/scripts/imported.dgsh"
echo!!(imported_greeting("Delegate"))

# === ONE-LINERS ===
x = 42; y = 10; echo!!(x + y)

if x > 10
    echo!!("x is big")
else
    echo!!("x is small")

# === FULL PIPELINE ===
double(x)
    return x * 2

add_ten(x)
    return x + 10

result = 5 -> double!($) -> add_ten!($)
echo!!("pipeline: {result}")

# === OBJECT SEND ===
user = { name = "Bob", score = 95 }
user -> echo!!("User {$name} scored {$score}")

# === LIST OPERATIONS ===
items = [3, 1, 4, 1, 5, 9, 2, 6]
echo!!("length: {len(items)}")
echo!!("contains 5: {contains(items, 5)}")
echo!!("contains 7: {contains(items, 7)}")

echo!!("all tests passed")
