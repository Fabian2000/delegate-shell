# === EXTERNAL COMMANDS ===

# ls is an exe — returns CommandResult
r? = ls("-la", "/tmp")
if r?
    print!!("ls status: {r.status}")
    print!!("ls ran successfully")

# === IMPORT ===
import "tests/scripts/imported.dgsh"
print!!(imported_greeting("Delegate"))

# === ONE-LINERS ===
x = 42; y = 10; print!!(x + y)

if x > 10
    print!!("x is big")
else
    print!!("x is small")

# === FULL PIPELINE ===
double(x)
    return x * 2

add_ten(x)
    return x + 10

result = 5 -> double!($) -> add_ten!($)
print!!("pipeline: {result}")

# === OBJECT SEND ===
user = { name = "Bob", score = 95 }
user -> print!!("User {$name} scored {$score}")

# === LIST OPERATIONS ===
items = [3, 1, 4, 1, 5, 9, 2, 6]
print!!("length: {len(items)}")
print!!("contains 5: {contains(items, 5)}")
print!!("contains 7: {contains(items, 7)}")

print!!("all tests passed")
