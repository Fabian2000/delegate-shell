# If/else
x = 10
if x > 5
    print!!("x is big")
else
    print!!("x is small")

# Nested if
y = 42
if y > 100
    print!!("over 100")
else
    if y > 40
        print!!("over 40")
    else
        print!!("40 or less")

# While loop
count = 0
while count < 5
    count += 1
print!!("count: {count}")

# For loop
for i in 1..5
    print!!(i)

# For loop over list
fruits = ["apple", "banana", "cherry"]
for f in fruits
    print!!("fruit: {f}")

# Function definition and call
greet(name)
    return "Hello, {name}"

result = greet!("Alice")
print!!(result)

# Function with arithmetic
add(a, b)
    return a + b

sum = add!(10, 20)
print!!("sum: {sum}")

# Recursive function
fib(n)
    if n <= 1
        return n
    return fib!(n - 1) + fib!(n - 2)

print!!("fib(10): {fib!(10)}")
